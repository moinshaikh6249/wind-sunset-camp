# Test credentials for automated E2E tests.
# IMPORTANT: Use dedicated test accounts that do not have access to production data.

# A standard registered user account
TEST_USER_EMAIL="testuser@example.com"
TEST_USER_PASSWORD="SecurePassword123"

# An admin user account (must be configured in Firestore /admins collection)
TEST_ADMIN_EMAIL="testadmin@example.com"
TEST_ADMIN_PASSWORD="SecureAdminPassword123"

# Ensure these users exist in your Firebase Auth and Firestore for tests to pass.
# The registration test will create its own user, but these are needed for login tests.
