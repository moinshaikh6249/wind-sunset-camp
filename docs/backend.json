{
  "entities": {
    "Admin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Admin",
      "type": "object",
      "description": "Represents an administrator with special privileges.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "super-admin"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile for the Sunset Camp application.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["fullName", "email", "createdAt"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "description": "Represents a camp booking.",
      "properties": {
        "userId": { 
          "type": "string",
          "description": "The UID of the user who made the booking, if authenticated."
        },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "campName": { "type": "string" },
        "peopleCount": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Canceled"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "campName", "peopleCount", "createdAt"]
    },
    "GalleryImage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GalleryImage",
      "type": "object",
      "description": "Represents an image in the gallery.",
      "properties": {
        "imageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "description", "createdAt"]
    },
    "Camp": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Camp",
      "type": "object",
      "description": "Represents an upcoming camp.",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "description", "createdAt"]
    },
    "Review": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Review",
      "type": "object",
      "description": "Represents a user-submitted review.",
      "properties": {
        "userId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment", "createdAt"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Represents a message submitted through the contact form.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Stores admin user roles and permissions. Document ID must match the admin's Firebase Auth UID."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores public user profile information. Document ID must match the user's Firebase Auth UID."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores all camp bookings from guests and registered users."
    },
    "/galleryImages/{imageId}": {
      "schema": { "$ref": "#/entities/GalleryImage" },
      "description": "Stores images for the public gallery."
    },
    "/camps/{campId}": {
      "schema": { "$ref": "#/entities/Camp" },
      "description": "Stores details about upcoming camps."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores user-submitted reviews."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "A centralized collection of all user messages from the contact form."
    }
  }
}
