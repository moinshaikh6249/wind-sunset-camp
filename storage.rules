
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow reads from anywhere, this is safe for public assets like profile pictures
    match /{allPaths=**} {
      allow read;
    }

    // Allow a user to write to their own profile picture directory
    match /profile-pictures/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
