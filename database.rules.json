{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "bookings": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        "history": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        "messages": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "admins": {
      ".read": "auth != null && auth.token.isAdmin === true",
      ".write": "auth != null && auth.token.isAdmin === true"
    },
    "camps": {
      ".read": true,
      ".write": "auth != null && auth.token.isAdmin === true"
    },
    "galleryImages": {
      ".read": true,
      ".write": "auth != null && auth.token.isAdmin === true"
    },
    "adminMessages": {
      ".read": "auth != null && auth.token.isAdmin === true",
      ".write": "auth != null"
    }
  }
}
