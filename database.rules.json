{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "bookings": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        "history": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        "messages": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "admins": {
      ".read": "auth != null && auth.token.isAdmin === true",
      "$uid": {
        ".write": "auth != null && auth.token.isAdmin === true"
      }
    },
    "camps": {
      ".read": true,
      ".write": "auth != null && auth.token.isAdmin === true"
    },
    "galleryImages": {
      ".read": true,
      ".write": "auth != null && auth.token.isAdmin === true"
    },
    "adminMessages": {
      ".read": "auth != null && auth.token.isAdmin === true",
      "$messageId": {
        // Allow any authenticated user to write a message
        ".write": "auth != null"
      }
    },
    "reviews": {
      ".indexOn": ["visible", "pinned"],
      // Allow public read only for reviews marked as visible
      "$reviewId": {
         ".read": "data.child('visible').val() === true",
         // Allow an authenticated user to write a review.
         // Allow an admin to update an existing review, but not change the userId.
         ".write": "auth != null && (newData.child('userId').val() === auth.uid || (auth.token.isAdmin === true && data.child('userId').val() === newData.child('userId').val()))"
      },
      // Allow admins to write to the top-level /reviews node (for bulk operations)
      ".write": "auth != null && auth.token.isAdmin === true"
    }
  }
}
