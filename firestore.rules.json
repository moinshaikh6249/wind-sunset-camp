
{
  "rules": {
    "reviews": {
      "$reviewId": {
        "read": "resource.data.visible == true",
        "create": "true",
        "update": "request.auth != null && root.child('admins').child(request.auth.uid).exists()",
        "delete": "request.auth != null && root.child('admins').child(request.auth.uid).exists()"
      }
    }
  }
}
