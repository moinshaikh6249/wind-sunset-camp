{
  "rules": {
    "reviews": {
      "$reviewId": {
        "allow read": "if resource.data.visible == true;",
        "allow create": "if true;",
        "allow update, delete": "if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data != null;"
      }
    }
  }
}
