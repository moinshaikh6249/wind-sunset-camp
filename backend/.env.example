# Environment Variables for Wind & Sunset Camp Backend

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wind-sunset-camp?retryWrites=true&w=majority

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Default Admin Bootstrap
DEFAULT_ADMIN_NAME=Moin Shaikh
DEFAULT_ADMIN_EMAIL=moinshaikh6249@gmail.com
DEFAULT_ADMIN_PASSWORD=change-this-strong-password

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Email Configuration (Optional - for future use)
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@windandsunsetcamp.com

# Logging
LOG_LEVEL=info

# Session Configuration
SESSION_SECRET=your-session-secret-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
