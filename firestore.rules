/**
 * @fileoverview Firestore Security Rules for Sunset Camp application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, meaning users can only
 * access their own profile data and bookings.  It prioritizes security by
 * explicitly denying potentially unsafe operations like listing all users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. The {userId} MUST match
 *   the Firebase Auth UID.
 * - /users/{userId}/bookings/{bookingId}: Stores booking information for each user.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data and bookings.
 * - Listing all users is explicitly denied.
 *
 * Denormalization for Authorization:
 *   The `userId` field within the `/users/{userId}/bookings/{bookingId}` subcollection
 *   MUST match the `userId` in the path to allow write access to the booking. This
 *   is enforced on creation, and immutability is enforced on updates.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get) Authenticated user can read their own profile.
     *   Example: User with UID 'user123' reading /users/user123
     * @allow (create) Authenticated user can create their own profile, where the userID in the path matches the user ID in the data.
     *   Example: User with UID 'user123' creating /users/user123
     * @allow (update) Authenticated user can update their own profile, if the user ID in the path matches the user ID in the data.
     *   Example: User with UID 'user123' updating /users/user123
     * @allow (delete) Authenticated user can delete their own profile, if the user ID in the path matches the user ID in the data.
     *   Example: User with UID 'user123' deleting /users/user123
     * @deny (get) Authenticated user cannot read other user profiles.
     *   Example: User with UID 'user123' reading /users/otherUser
     * @deny (list) Listing all users is not allowed.
     * @deny (create) Unauthenticated user cannot create a profile.
     * @deny (update) Authenticated user cannot update other user profiles.
     * @deny (delete) Authenticated user cannot delete other user profiles.
     * @principle Enforces document ownership, restricting access to the authenticated user's own profile.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Helper function to check if the user is an existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to booking documents within a user's profile.
     * @path /users/{userId}/bookings/{bookingId}
     * @allow (get) Authenticated user can read their own bookings.
     *   Example: User 'user123' reading /users/user123/bookings/booking456
     * @allow (create) Authenticated user can create bookings under their own profile,
     *   and the 'userId' field in the booking data must match the 'userId' in the path.
     *   Example: User 'user123' creating /users/user123/bookings/booking456 with data { userId: 'user123', ... }
     * @allow (update) Authenticated user can update their own bookings, where the userID in the path matches the user ID in the data.
     *   Example: User with UID 'user123' updating /users/user123/bookings/booking456
     * @allow (delete) Authenticated user can delete their own bookings.
     *   Example: User 'user123' deleting /users/user123/bookings/booking456
     * @deny (get) Authenticated user cannot read bookings of other users.
     *   Example: User 'user123' attempting to read /users/otherUser/bookings/booking789
     * @deny (list) Authenticated user can read their own bookings.
     *   Example: User 'user123' listing /users/otherUser/bookings
     * @deny (create) Authenticated user cannot create bookings under other user profiles.
     *   Example: User 'user123' attempting to create /users/otherUser/bookings/booking456
     * @deny (update) Authenticated user cannot update bookings of other users.
     *   Example: User 'user123' attempting to update /users/otherUser/bookings/booking789
     * @deny (delete) Authenticated user cannot delete bookings of other users.
     *   Example: User 'user123' attempting to delete /users/otherUser/bookings/booking789
     * @principle Enforces strict ownership for bookings, ensuring users can only manage bookings associated with their profile.
     */
    match /users/{userId}/bookings/{bookingId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the booking
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Helper function to check if the user is an existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}