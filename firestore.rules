rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins can read their own roles, but clients cannot write to the admins collection.
    // This must be done manually in the Firebase Console or via a trusted server environment.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    // Users can create their own profile on signup.
    // They can only read or update their own data. Admins can manage any user.
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read, update: if isAuth() && request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Anyone (including guests) can create a booking.
    // Logged-in users can read their own bookings.
    // Admins can read, update, and delete any booking.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Anyone can read reviews that are marked as visible.
    // Only authenticated users can create reviews for themselves.
    // Admins can update or delete any review.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Anyone can read public camp and gallery data.
    // Only admins can write to these collections.
    match /galleryImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /camps/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Anyone can submit a message through the contact form.
    // Only admins can read or delete messages.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
