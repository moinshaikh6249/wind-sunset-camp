rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins: Manually managed in Firebase Console. Read-only for other admins.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    // Users: Can create their own profile. Can only read/update their own data. Admins can manage any user.
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read, update: if isAuth() && request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Bookings: Anyone can create. Logged-in users can read their own. Admins can manage all.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Reviews: Public read. Authenticated users can create. Admins can manage.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Gallery & Camps: Public read. Admin-only write.
    match /galleryImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /camps/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages: Anyone can create. Admins can manage.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
