rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check authentication and admin status.
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection: Read-only for other admins, no client-side writes.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Admin documents should be managed via the Firebase Console.
    }

    // Users Collection: Users can manage their own profile. Admins can manage any user.
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read, update: if (isAuth() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings Collection: Authenticated users can create for themselves. Admins manage all.
    match /bookings/{bookingId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Reviews Collection: Public read. Authenticated users can create/manage their own. Admins manage all.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Gallery and Camps: Public read, admin-only write access.
    match /galleryImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /camps/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages Collection: Anyone can submit a message. Only admins can read/manage them.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
