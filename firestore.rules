rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super-admin';
    }

    // Admins Collection
    // - Super-admins can manage other admins.
    // - Regular admins can read the list.
    // - No client-side creation by non-super-admins.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // Users Collection
    // - Users can create their own account document.
    // - Users can read/update their own data.
    // - Admins can manage all user documents.
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Bookings Collection
    // - Anyone can create a booking.
    // - Only admins can read/manage bookings.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Gallery Images Collection
    // - Publicly readable.
    // - Admin-only writes.
    match /galleryImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Camps Collection
    // - Publicly readable.
    // - Admin-only writes.
    match /camps/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews Collection
    // - Publicly readable.
    // - Authenticated users can create reviews for themselves.
    // - Admins can moderate (update/delete).
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Messages Collection
    // - Anyone can create a message (contact form).
    // - Only admins can read/manage messages.
    match /messages/{messageId} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
    }
  }
}
