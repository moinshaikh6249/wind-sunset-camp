rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check if the user's UID exists in the admins collection.
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      // Check if the requesting user is the owner of the document.
      return isAuth() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // Admins: Manually managed in Firebase Console. Read-only for other admins.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Disable all client-side writes to the admins collection.
    }

    // Users: Users manage their own profile. Admins can manage any user.
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Bookings: Authenticated users create and manage their own. Admins manage all.
    match /bookings/{bookingId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Reviews: Public read. Authenticated users create for themselves and manage their own. Admins manage all.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // Public Content: Publicly readable, admin-only write access.
    match /galleryImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /camps/{campId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages: Anyone can create (contact form). Only admins can read/manage.
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
